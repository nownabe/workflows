{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>nownabe/renovate-config"],

  // Repo-specific additions on top of the shared preset.
  //
  // Each reusable workflow pins the tool it runs inline via an `env.TOOL`
  // value (e.g. `TOOL: npm:oxlint@1.69.0`), independently of any mise.toml so
  // that callers' mise settings are ignored (MISE_LOCKED: "0"). The shared
  // preset's `mise` manager only reads mise.toml, so these inline versions
  // would otherwise never be updated. These custom managers keep them current.
  //
  // (Arrays from `extends` presets are concatenated with these, so the
  // preset's own customManagers/packageRules remain in effect.)
  customManagers: [
    // npm-backed tools: `TOOL: npm:<pkg>@<version>`
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/.+\\.ya?ml$/"],
      matchStrings: ["TOOL: npm:(?<depName>[^@\\s]+)@(?<currentValue>\\S+)"],
      datasourceTemplate: "npm",
      depTypeTemplate: "workflow-tool",
    },
    // aqua-backed tools: `TOOL: aqua:<owner>/<repo>@<version>`
    // aqua packages map to GitHub releases; tags are `v`-prefixed.
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/.+\\.ya?ml$/"],
      matchStrings: ["TOOL: aqua:(?<depName>[^@\\s]+)@(?<currentValue>\\S+)"],
      datasourceTemplate: "github-releases",
      extractVersionTemplate: "^v(?<version>.+)$",
      depTypeTemplate: "workflow-tool",
    },
  ],

  packageRules: [
    // Group the inline workflow tool bumps into one PR, committed as `deps:`.
    //
    // The shared preset's top-level `semanticCommitType: "deps"` is overridden
    // by config:recommended's `:semanticPrefixFixDepsChoreOthers`, which types
    // production deps as `fix` and everything else (including this custom
    // `workflow-tool` depType) as `chore`. A packageRule wins over that preset
    // rule, so set the type here. No scope so the prefix is a bare `deps:`.
    {
      matchDepTypes: ["workflow-tool"],
      semanticCommitType: "deps",
      groupName: "workflow pinned tools",
    },
  ],
}
